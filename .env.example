DATABASE_URL="file:./dev.db"

# === Required for runtime ===
GOOGLE_PLACES_API_KEY=
# Personalization runs through the local `claude` CLI on your Max sub.
# If `claude` isn't on PATH, set CLAUDE_BIN to the full path:
# CLAUDE_BIN=/opt/homebrew/bin/claude

# === Email tracker (https://email.buggers.online) ===
TRACKER_BASE_URL=https://email.buggers.online
TRACKER_EMAIL=
TRACKER_PASSWORD=

# === Cron auth (optional) ===
# If set, /api/cron/follow-ups requires Authorization: Bearer <secret>.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# === Audit funnel (Stripe + public URL) ===
# Where the audit funnel is publicly reachable. Used to build success URLs.
# Examples: https://sendprop.com, https://audit.sendprop.com
PUBLIC_BASE_URL=
# From https://dashboard.stripe.com/apikeys (use test keys until you're ready
# to take real money). Server-side only — never expose to client.
STRIPE_SECRET_KEY=
# From the webhook endpoint you create at
# https://dashboard.stripe.com/webhooks (point it at /api/stripe/webhook).
STRIPE_WEBHOOK_SECRET=
