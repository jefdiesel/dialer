// Dialer schema — outreach pipeline for AI consulting
// Tracking (opens/clicks/replies) is handled by the external tracker, NOT here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  niche       String   // e.g. "dental clinics", "law firms"
  location    String   // e.g. "Austin, TX"
  pitch       String   // free-form: what we're offering, hourly rate, hooks
  status      String   @default("draft") // draft | discovering | enriching | ready | sending | done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leads       Lead[]
}

model Lead {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Discovery (Google Places)
  placeId      String?   @unique
  businessName String
  website      String?
  phone        String?
  address      String?
  category     String?

  // Enrichment
  enrichedAt   DateTime?
  primaryEmail String?
  ownerName    String?
  enriched     String?   // JSON blob: signals, tech stack, pages scraped
  fitScore     Int?      // 0-100, how good of an AI-consult fit

  // Pipeline state
  status       String    @default("new") // new | enriched | drafted | approved | handed_off | rejected | failed | replied
  notes        String?

  // Multi-touch sequence state
  repliedAt    DateTime?  // when the lead responded; pauses any future touches

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  drafts       Draft[]

  @@index([campaignId, status])
}

// Inbound funnel: someone clicks the cold email link, lands on /audit,
// pays via Stripe, uploads their data, and waits for the report.
//
// Lifecycle:
//   pending      - Stripe session created, payment not yet confirmed
//   paid         - webhook received checkout.session.completed
//   uploaded     - client signed NDA and uploaded data
//   delivered    - consultant has emailed the report
//   refunded     - refund issued (manually via Stripe)
model AuditOrder {
  id                 String   @id @default(cuid())
  stripeSessionId    String   @unique
  stripePaymentIntent String?
  customerEmail      String
  customerName       String?
  businessName       String?
  amountCents        Int      @default(40000) // $400.00
  status             String   @default("pending") // pending | paid | uploaded | delivered | refunded
  ndaAcceptedAt      DateTime?
  ndaIp              String?
  uploadedAt         DateTime?
  uploadedFiles      String?  // JSON array of file metadata
  notes              String?
  paidAt             DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([customerEmail])
}

model Playbook {
  id                  String   @id @default(cuid())
  industrySlug        String   @unique // e.g. "dental-clinics", "law-firms"
  name                String              // Human-readable: "Dental Clinics"
  summary             String              // 1-2 sentence description
  markdown            String              // Full playbook content — the consult deliverable
  top3UseCases        String              // JSON: [{title, painPoint, capability}] — fed to personalizer
  citations           String              // JSON: [{title, url, quote}]
  status              String   @default("draft") // draft | published
  researchTranscript  String?             // raw CLI output for audit
  model               String?             // model used to generate
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model Draft {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel    String   @default("email") // email | linkedin | contact_form
  subject    String?
  body       String
  model      String?  // which Claude model produced it
  status     String   @default("draft") // draft | approved | handed_off | failed | scheduled | skipped
  handoffRef String?  // ID returned by tracker after push
  handoffAt  DateTime?

  // Multi-touch sequence
  step       Int       @default(0) // 0 = initial, 1 = day-3 bump, 2 = day-7 closeout
  dueAt      DateTime?              // for scheduled follow-ups: when this should fire

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([leadId])
  @@index([status, dueAt])
}
